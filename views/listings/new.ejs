<form action="/listings" method="POST" enctype="multipart/form-data" class="card">
  <div class="card-body">
    <h2>Create Listing</h2>
    <label class="form-row">House Name
      <input type="text" name="listing[title]" required />
    </label>

    <label class="form-row">Price
      <input type="number" name="listing[price]" required />
    </label>

    <label class="form-row">Location
      <input type="text" name="listing[location]" />
    </label>

    <label class="form-row">Country
      <input type="text" name="listing[country]" />
    </label>

    <label class="form-row">Description
      <textarea name="listing[description]" rows="5"></textarea>
    </label>

    <label class="form-row">Rating (optional)
      <input type="number" name="listing[rating]" min="0" max="5" step="0.1" />
    </label>

    <label class="form-row">Upload Images
      <input type="file" name="images" accept="image/*" multiple />
    </label>

    <div class="form-row">
      <button class="btn" type="submit">Create</button>
      <a href="/listings" class="btn btn-ghost">Cancel</a>
    </div>
  </div>
</form>
